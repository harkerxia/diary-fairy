{
  "api_config": {
    "provider": "anthropic",
    "model": "claude-sonnet-4-6",
    "parameters": {
      "temperature": 0.8,
      "max_tokens": 4096
    }
  },
  "entities": {
    "user_name": "User",
    "bot_name": "Frieren"
  },
  "storage_paths": {
    "input_logs": "chat_logs",
    "output_archives": {
      "daily": "archives/daily",
      "weekly": "archives/weekly",
      "monthly": "archives/monthly",
      "yearly": "archives/yearly",
      "diary": "archives/diary"
    }
  }
}
