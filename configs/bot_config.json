{
  "model": "gpt-4o-mini",
  "parameters": {
    "temperature": 0.8,
    "presence_penalty": 0.2,
    "frequency_penalty": 0.2
  },
  "bot_name": "Frieren",
  "user_name": "Harker",
  "memory_system": {
    "strategy": "hierarchical_cognitive_architecture",
    "inject_templates": {
      "core": "<core_memory>\n{core_summary}\n</core_memory>",
      "yearly": "<yearly_memory>\n{yearly_summary}\n</yearly_memory>",
      "monthly": "<monthly_memory>\n{monthly_summary}\n</monthly_memory>",
      "weekly": "<weekly_memory>\n{weekly_summary}\n</weekly_memory>"
    }
  },
  "logs": {
    "start": "System started. Model: {model}, Bot: {bot_name}",
    "chat": "[{user_name}]: {text}",
    "error": "Error: {error}"
  }
}